:root {
    --page-bg: #FFFFFF;
    --text-main: #111111;
    --text-muted: #444444;
    --blue-title: #2454D3;
    --line-dark: #1A1A1A;
    --card-bg: #F3F4F6;
    --card-border: #E5E7EB;

    --status-final-bg: #DCFCE7;
    --status-final-text: #166534;

    --status-temp-bg: #FEF3C7;
    --status-temp-text: #92400E;

    --timeline-default-dot: #3B82F6;
    --timeline-default-date: #6B7280;

    --timeline-old-dot: #9CA3AF;
    --timeline-old-date: #9CA3AF;

    --timeline-prog-dot: #DC2626;
    --timeline-prog-date: #B91C1C;

    --timeline-latest-dot: #16A34A;
    --timeline-latest-date: #15803D;
}

html, body, [data-testid="stAppViewContainer"], .stApp {
    background: var(--page-bg);
    color: var(--text-main);
}

.block-container {
    max-width: 1480px;
    padding-top: 20px;
    padding-bottom: 96px;
    padding-left: 40px;
    padding-right: 40px;
}

/* ---------------- Header ---------------- */
.title-shell {
    min-height: 132px;
    display: flex;
    align-items: center;
}

.title-left {
    justify-content: flex-start;
}

.title-right {
    justify-content: flex-start;
}

.report-title-main {
    font-size: 31px;
    line-height: 1.22;
    font-weight: 800;
    color: var(--blue-title);
    letter-spacing: -0.02em;
    margin: 0;
    text-align: left;
}

.logo-placeholder-equal {
    width: 100%;
    min-height: 120px;
    border: 1px dashed #C7CCD4;
    border-radius: 14px;
    background: #FAFAFA;
    color: #7B8794;
    font-size: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
}

/* ---------------- Section titles ---------------- */
.section-title-frame {
    border-top: 2px solid var(--line-dark);
    border-bottom: 1px solid #A3A3A3;
    padding-top: 10px;
    padding-bottom: 10px;
    margin-top: 22px;
    margin-bottom: 16px;
}

.section-title-text {
    font-size: 18px;
    line-height: 1.25;
    font-weight: 700;
    color: #111111;
}

.subsection-title-row {
    display: flex;
    align-items: center;
    min-height: 36px;
}

.subsection-title-text {
    font-size: 16px;
    line-height: 1.3;
    font-weight: 700;
    color: #111111;
    margin: 0;
}

/* ---------------- Edit button alignment ---------------- */
.stButton > button {
    width: 100%;
    border-radius: 10px;
}

div[data-testid="stHorizontalBlock"] .stButton {
    display: flex;
    align-items: center;
    height: 100%;
}

/* ---------------- Meta block ---------------- */
.meta-card {
    background: #FFFFFF;
    border: none;
    border-radius: 0;
    padding: 4px 0 12px 0;
    margin-bottom: 8px;
}

.meta-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 28px;
    align-items: center;
    font-size: 13px;
    line-height: 1.45;
    color: #111111;
}

.meta-item {
    display: inline-flex;
    align-items: center;
}

/* ---------------- Status badge ---------------- */
.status-badge {
    display: inline-flex;
    align-items: center;
    padding: 4px 10px;
    border-radius: 999px;
    font-weight: 700;
    font-size: 12px;
    margin-left: 6px;
}

.status-final {
    background: var(--status-final-bg);
    color: var(--status-final-text);
}

.status-temp {
    background: var(--status-temp-bg);
    color: var(--status-temp-text);
}

/* ---------------- Cards ---------------- */
.info-card {
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    border-radius: 14px;
    padding: 16px 18px;
    margin-top: 8px;
    margin-bottom: 14px;
}

.info-row {
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: 10px;
    align-items: start;
    padding-top: 8px;
    padding-bottom: 8px;
    border-bottom: 1px solid rgba(0, 0, 0, 0.05);
}

.info-row:last-child {
    border-bottom: none;
}

.info-label {
    font-size: 12.5px;
    line-height: 1.35;
    font-weight: 600;
    color: #333333;
}

.info-value {
    font-size: 12.5px;
    line-height: 1.45;
    font-weight: 400;
    color: #111111;
    white-space: pre-wrap;
    word-break: break-word;
}

/* ---------------- Timeline ---------------- */
.timeline-card {
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    border-radius: 14px;
    padding: 20px 18px 18px 18px;
    margin-top: 8px;
    margin-bottom: 14px;
    overflow-x: auto;
}

.timeline-horizontal-wrap {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 0;
    min-width: 820px;
}

.timeline-h-item {
    position: relative;
    padding-right: 18px;
}

.timeline-h-top {
    min-height: 28px;
    margin-bottom: 8px;
}

.timeline-h-date {
    font-size: 12px;
    font-weight: 700;
}

.timeline-h-middle {
    position: relative;
    height: 20px;
    margin-bottom: 12px;
}

.timeline-h-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    position: absolute;
    left: 0;
    top: 4px;
    z-index: 2;
}

.timeline-h-connector {
    position: absolute;
    left: 12px;
    right: 8px;
    top: 8px;
    height: 2px;
    background: #CBD5E1;
}

.timeline-h-bottom {
    padding-right: 8px;
}

.timeline-h-stage {
    font-size: 13px;
    font-weight: 700;
    color: #111111;
    margin-bottom: 6px;
}

.timeline-h-desc {
    font-size: 12px;
    line-height: 1.45;
    color: #111111;
}

.tl-default .timeline-h-dot {
    background: var(--timeline-default-dot);
}
.tl-default .timeline-h-date {
    color: var(--timeline-default-date);
}

.tl-surgery-old .timeline-h-dot {
    background: var(--timeline-old-dot);
}
.tl-surgery-old .timeline-h-date {
    color: var(--timeline-old-date);
}

.tl-progression .timeline-h-dot {
    background: var(--timeline-prog-dot);
}
.tl-progression .timeline-h-date {
    color: var(--timeline-prog-date);
}

.tl-latest .timeline-h-dot {
    background: var(--timeline-latest-dot);
}
.tl-latest .timeline-h-date {
    color: var(--timeline-latest-date);
}

.timeline-empty {
    font-size: 13px;
    color: #666666;
}

/* ---------------- Inputs ---------------- */
label, .stTextInput label, .stTextArea label, .stDateInput label, .stSelectbox label {
    color: #111111 !important;
    font-size: 12.5px !important;
    font-weight: 600 !important;
}

[data-testid="stTextInputRootElement"] input,
[data-testid="stTextArea"] textarea,
[data-baseweb="select"] > div,
[data-testid="stDateInputField"] input {
    background-color: #F3F4F6 !important;
    color: #111111 !important;
    -webkit-text-fill-color: #111111 !important;
    border-radius: 10px !important;
}

[data-testid="stTextInputRootElement"] > div,
[data-testid="stTextAreaRootElement"] > div,
[data-testid="stDateInputField"] > div,
[data-baseweb="select"] {
    border-color: #D1D5DB !important;
    background: #F3F4F6 !important;
}

[data-baseweb="select"] span,
[data-baseweb="select"] div {
    color: #111111 !important;
}

input::placeholder,
textarea::placeholder {
    color: #6B7280 !important;
    opacity: 1;
}

/* ---------------- Bottom mode indicator ---------------- */
.dashboard-mode-footer {
    position: fixed;
    left: 32px;
    right: 32px;
    bottom: 16px;
    display: flex;
    justify-content: flex-end;
    align-items: center;
    gap: 10px;
    z-index: 999;
    pointer-events: none;
}

.dashboard-mode-label {
    font-size: 13px;
    font-weight: 700;
    color: #111111;
    background: rgba(255, 255, 255, 0.92);
    padding: 8px 12px;
    border-radius: 999px;
    border: 1px solid #E5E7EB;
}

.dashboard-mode-pill {
    font-size: 13px;
    font-weight: 700;
    padding: 8px 14px;
    border-radius: 999px;
    border: 1px solid #E5E7EB;
    background: rgba(255, 255, 255, 0.96);
}

.dashboard-mode-view {
    color: #1F2937;
}

.dashboard-mode-edit {
    color: #7C2D12;
    background: #FFEDD5;
    border-color: #FDBA74;
}